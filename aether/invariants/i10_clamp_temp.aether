(@intent "AetherLife I10 — température clampée dans [temp_min, temp_max]")
(@example -50 -10 30 -10)
(@example 50 -10 30 30)
(@example 15 -10 30 15)
(@example -10 -10 30 -10)
(@example 30 -10 30 30)
(@invariant (>= result temp_min))
(@invariant (<= result temp_max))
(fn clamp_temp ((temp num) (temp_min num) (temp_max num)) num
  (max temp_min (min temp_max temp)))
