(@intent "AetherLife I22 — bruit gaussien sur un poids reste fini si parent fini et std bornee")
(@example 0.5 0.1 0.6)
(@example -0.3 -0.05 -0.35)
(@example 1.5 0.0 1.5)
(@example 0.0 0.001 0.001)
(@example 10.0 -2.0 8.0)
(@invariant (= result (+ parent_w noise)))
(@invariant (or (>= result -1000) (<= result 1000)))
(fn weight_after_mutation ((parent_w num) (noise num)) num
  (+ parent_w noise))
