(@intent "AetherLife I1 — énergie après step sans manger : energy - metabolism, clampée à 0")
(@example 10 1 9)
(@example 5 3 2)
(@example 1 1 0)
(@example 0 1 0)
(@example 2 5 0)
(@invariant (>= result 0))
(@invariant (<= result energy))
(fn energy_no_food ((energy num) (metabolism num)) num
  (max 0 (- energy metabolism)))
